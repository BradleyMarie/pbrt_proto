
Film "image" 
	"integer xresolution" [256] "integer yresolution" [512] 
#	"integer xresolution" [600] "integer yresolution" [1200] 
Sampler "lowdiscrepancy" "integer pixelsamples" [4]
PixelFilter"box"

LookAt 0 .2 .2    0 .11 0  0 1 0
Camera "perspective" "float fov" [36] 

WorldBegin

AttributeBegin
   AreaLightSource "area" "color L" [ 4 4 4 ] "integer nsamples" [8]
   Translate 0 2 0
   Rotate 90 1 0 0
   Shape "disk" "float radius" [3]
AttributeEnd

AttributeBegin
Material "matte" "color Kd" [.4 .42 .48]
Shape "trianglemesh" "point P" [ -1 0 -1 1 0 -1 1 0 1 -1 0 1 ]
	"integer indices" [ 0 1 2 2 3 0]
Shape "trianglemesh" "point P" [ -1 0 -1  1 0 -1  1 1 -1 -1 1 -1 ]
	"integer indices" [ 0 1 2 2 3 0]
AttributeEnd

Material "bluepaint"

Include "geometry/happy.pbrt"

WorldEnd

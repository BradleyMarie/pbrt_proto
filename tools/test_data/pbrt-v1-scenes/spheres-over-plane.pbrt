
#LookAt 4 .5 -15   0 0 0   0 1 0
Rotate -15 1 0 0
Rotate 16 0 1 0
Translate -4 -.5 15
Camera "perspective" "float fov" [50]

Film "image" "integer xresolution" [638] "integer yresolution" [383]
#Film "image" "integer xresolution" [3825] "integer yresolution" [2295]
Sampler "bestcandidate" "integer pixelsamples" [2]
SurfaceIntegrator "directlighting" "integer maxdepth" [10]

WorldBegin
AttributeBegin
CoordSysTransform "camera"
#LightSource "point"
AttributeEnd

AttributeBegin
AreaLightSource "area" "color L" [3000000 3000000 3000000] "integer nsamples" [4]
Translate 0 20 0
Rotate 90 1 0 0
Shape "disk" "float radius" [.02]
AttributeEnd

AttributeBegin
Texture "grid" "color" "imagemap" "string filename" ["textures/lines.exr"]
Texture "sgrid" "color" "scale" "texture tex1" "grid" "color tex2" [ .5 .5 .5 ]
Material "matte" "texture Kd" "sgrid"
Translate 0 0 -2
Shape "trianglemesh" "point P" [ -40 -3 -40 40 -3 -40 40 -3 40 -40 -3 40 ]
      "float uv" [ 0 0 2 0 2 2 0 2 ]
	"integer indices" [ 0 1 2 2 3 0]
AttributeEnd



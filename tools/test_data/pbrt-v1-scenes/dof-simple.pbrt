Camera "perspective" "float fov" [45]
	"float focaldistance" [10] "float lensradius" [.5]
Film "image" "integer xresolution" [300] "integer yresolution" [300] 
	"float cropwindow" [.2 .5 .2 .5 ]

#Sampler "bestcandidate" "integer pixelsamples" [512]

Sampler "bestcandidate" "integer pixelsamples" [16]
#Sampler "lowdiscrepancy" "integer pixelsamples" [16]
#Sampler "stratified" "integer xsamples" [4] "integer ysamples" [4]
#Sampler "random" "integer xsamples" [4] "integer ysamples" [4]

PixelFilter "box" "float xwidth" [.5] "float ywidth" [.5] 

WorldBegin
LightSource "distant" "point from" [-1 1 4] "point to" [ 0 0 5]

Translate 0 0 5
Material "plastic" "color Kd" [1 .2 .2 ] "color Ks" [4 4 4 ]
	"float roughness" [.02]
Shape "sphere"
WorldEnd

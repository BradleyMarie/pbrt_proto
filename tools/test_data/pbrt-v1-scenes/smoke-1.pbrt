
LookAt 3.3 4 -4   1.2 .7 0    0 1 0
Camera "perspective" "float fov" [28]
Film "image" "integer xresolution" [500] "integer yresolution" [500]

Sampler "bestcandidate" "integer pixelsamples" [4]

VolumeIntegrator "single" "float stepsize" [.05]

WorldBegin

#LightSource "point" "point from" [0 10 2] "color I" [100 100 100]
AttributeBegin
AreaLightSource "area" "color L" [9500 9500 9500 ] "integer nsamples" [8]
Translate 4 15 -2
Rotate 80 1 0 0
Shape "disk" "float radius" [.2]
AttributeEnd

Include "geometry/density_render.60.1.pbrt"

Material "matte" "color Kd" [.57 .57 .6]
Translate 0 -1 0
Shape "trianglemesh" "integer indices" [0 1 2 2 3 0]
	"point P" [ -5 0 -5  5 0 -5  5 0 5  -5 0 5]
Material "matte" "color Kd" [1.71 1.71 1.8]
Shape "trianglemesh" "integer indices" [0 1 2 2 3 0]
	"point P" [ -5 0 1.7  5 0 1.7   5 10 1.7  -5 10 1.7 ]

WorldEnd

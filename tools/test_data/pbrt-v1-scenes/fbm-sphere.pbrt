Film "image"
	"integer xresolution" [200] "integer yresolution" [100]
	"integer xresolution" [300] "integer yresolution" [300]
#	"integer xresolution" [900] "integer yresolution" [900]
#"integer xresolution" [2775] "integer yresolution" [2775]
Sampler "lowdiscrepancy" "integer pixelsamples" [8] 
PixelFilter "box"

LookAt 0 3 8  0 .8 0   0 1 0
Camera "perspective" "float fov" [22]

SurfaceIntegrator "directlighting"

WorldBegin

AttributeBegin
  CoordSysTransform "camera"
  AreaLightSource "area" "color L" [12 12 12  ] "integer nsamples" [2]
  Translate 0 2 -10
  Material "matte" "color Kd" [ 0 0 0 ]
  Shape "disk" "float radius" [3] 
AttributeEnd

AttributeBegin
  AreaLightSource "area" "color L" [4 4 4] "integer nsamples" [2]
  Translate 0 10 2
  Rotate 90 1 0 0 
  Material "matte" "color Kd" [ 0 0 0 ]
  Shape "disk" "float radius" [5] 
AttributeEnd

AttributeBegin
  Material "matte" "color Kd" [.8 .8 .8 ]
  Shape "trianglemesh" "integer indices" [ 0 1 2 2 0 3 ]
    "point P" [-10 0 -10   10 0 -10   10 0 10   -10 0 10 ]
  Shape "trianglemesh" "integer indices" [ 0 1 2 2 0 3 ]
    "point P" [-10 0 -10   10 0 -10   10 9 -10   -10 9 -10 ]
  Shape "trianglemesh" "integer indices" [ 0 1 2 2 0 3 ]
    "point P" [-10 0 -10   -10 0 10   -10 9 10   -10 9 -10 ]
AttributeEnd

Texture "bump" "float" "fbm"
#Texture "bump" "float" "wrinkled"
Material "uber" "color Kd" [.6 .6 .7 ] "color Ks" [.05 .05 .05]
	 "float roughness" [.01] "texture bumpmap" "bump"

AttributeBegin
Translate 0 1 0
Shape "sphere"
AttributeEnd

WorldEnd

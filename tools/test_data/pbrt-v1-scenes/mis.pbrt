
LookAt 400 20 30   0 63 -110   0 0 1
Rotate -5 0 0 1
Camera "perspective" "float fov" [39]
Film "image"  
"integer xresolution" [300] "integer yresolution" [300]

Sampler "lowdiscrepancy" "integer pixelsamples" [4] # [64]

SurfaceIntegrator "directlighting" # "string sample" "light"

WorldBegin

AttributeBegin
Material "matte" "color Kd" [0 0 0]
AreaLightSource "area"  "color L" [ 3 3 .5] "integer nsamples" [1] #10 10 10
Translate -250 0  -50
Shape "sphere" "float radius" [60]

Translate 0 120 0
AreaLightSource "area"  "color L" [300 1200 1200 ] "integer nsamples" [1] #10 10 10
Shape "sphere" "float radius" [3]

AttributeEnd


AttributeBegin
  Material "matte" "color Kd" [.5 .5 .5]
  Translate 0 0 -140
Texture "r1" "float" "constant" "float value" [.001]
Texture "r2" "float" "constant" "float value" [.03]
Texture "roughtex" "float" "checkerboard" "texture tex1" "r1" "texture tex2" "r2"
Material "plastic" "color Kd" [.005 .005 .005 ] "color Ks" [.5 .5 1] "texture roughness" "roughtex"
Shape "trianglemesh" "point P" [ -1000 -1000 0 1000 -1000 0 1000 1000 0 -1000 1000 0 ]
      "float uv" [ 0 0 50 0 50 50 0 50 ]
	"integer indices" [ 0 1 2 2 3 0]
AttributeEnd

WorldEnd

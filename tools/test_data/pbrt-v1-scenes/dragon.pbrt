Film "image" 
	"integer xresolution" [600] "integer yresolution" [900] 
#	"integer xresolution" [900] "integer yresolution" [900]

SurfaceIntegrator "photonmap" "integer causticphotons" [200000]
        "integer indirectphotons" [00]
        "integer directphotons" [0]
        "integer finalgathersamples" [32]
            "bool finalgather" ["false"] "integer nused" [150]
    "bool directwithphotons" ["false"] "float maxdist" [.2]

Sampler "bestcandidate" "integer pixelsamples" [1]

# far away view, fits area light
#LookAt 0 .3 .5    0 .16 0  0 1 0
#Camera "perspective" "float fov" [60] 

# zoom in on dragon only
LookAt 0 .3 .5 -.01 .06 0 0 1 0
Camera "perspective" "float fov" [33]

VolumeIntegrator "single" "float stepsize" .05

WorldBegin

# -.1 0 -.05 -> .1 .16 .05 tight fit
#Volume "exponential"  "float a" [15] "float b" [50] "vector updir" [0 1 0]
#	"color sigma_a" [1 1 1]
#	"color sigma_s" [5 5 5] "point p0" [-.5 0 -.5 ]
#	"color Le" [.1 .1 .1]
#	"point p1" [.5 .16 .5]
  
AttributeBegin
   AreaLightSource "area" "color L" [ 600 600 600 ]  "integer nsamples" [4]
   Translate 0 .35 0 
   Rotate 90 1 0 0
   Shape "disk" "float radius" [.02]
AttributeEnd

AttributeBegin
   AreaLightSource "area" "color L" [ 20 20 20 ]  "integer nsamples" [16]
   Translate 0 .35  0
   Rotate 90 1 0 0
#   Shape "disk" "float radius" [.1]
AttributeEnd

#LightSource "point" "point from" [0 .35 0] "color I" [.65 .65 .65]
#LightSource "spot" "point from" [0 .35 0] "point to" [-.012 0 0] "color I" [.6 .6 .6] "float coneangle" [27]
AttributeBegin
Translate 0 .25 0
#LightSource "goniometric" "string mapname" ["textures/gonio1.exr"]
AttributeEnd

AttributeBegin
  Translate -.2 .25 .2
  Rotate -35 1 0 0
  Rotate 150 0 1 0
  #LightSource "projection" "string mapname"  ["textures/lines.exr"] "float fov" [55]
AttributeEnd

AttributeBegin
Material "matte" "color Kd" [.8 .8 .8]
Shape "trianglemesh" "point P" [ -1 0 -1 1 0 -1 1 0 1 -1 0 1 ]
	"integer indices" [ 0 1 2 2 3 0]
Shape "trianglemesh" "point P" [ -1 0 -1  1 0 -1  1 3 -1 -1 3 -1 ]
	"integer indices" [ 0 1 2 2 3 0]
AttributeEnd

TransformBegin
Scale 100 100 100 # .001 .001 .001
Texture "c1" "color" "constant" "color value" [.8 .7 .2 ]
Texture "c2" "color" "constant" "color value" [.2 .4 .8 ]
Texture "check" "color" "checkerboard" "integer dimension" [3] "texture tex2" "c1"
	"texture tex1" "c2"
Material "matte" "texture Kd" "check"
TransformEnd
Material "bluepaint"
Material "glass"
Include "geometry/dragon.pbrt"

WorldEnd

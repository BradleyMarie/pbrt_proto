
LookAt -15 5 6.5   4 2 5.5  0 0 1

Camera "perspective" "float fov" [60 ] "float focaldistance" [10] 
#	"float lensradius" [ .08]
Film "image"  "integer xresolution" [800 ] "integer yresolution" [500 ] 

SurfaceIntegrator "irradiancecache" "integer nsamples" [256] "float maxerror" [.2]

VolumeIntegrator "single" "float stepsize" [1.5]

WorldBegin

#Volume "homogeneous"
#	"point p0" [-30 -30 0] "point p1" [30 30 10] 
#	"color sigma_a" [.00 .00 .00 ]
#	"color sigma_s" [.04 .04 .04 ]

AttributeBegin
CoordSysTransform "camera"
LightSource "point" "color I" [10 10 10]  "point from" [0 0 0]
AttributeEnd

#####LightSource "distant" "color L" [35 32 28  ] "point from" [-5 5 30] "point to" [0 -3 0]
LightSource "spot" "color I" [200000 170000 150000  ] "point from" [0 -30 60]
	"point to" [0 3 6] "float coneangle" [45]

AttributeBegin
AreaLightSource "area" "color L" [12 12 14 ] "integer nsamples" [31]
ReverseOrientation
Material "matte" "color Kd" [0 0 0 ]
#Shape "disk" "float radius" [100] "float height" [64]
AttributeEnd

Include "geometry/sponzageom.pbrt"

WorldEnd
